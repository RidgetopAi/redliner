{
  "name": "redliner",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "npm run -w client dev",
    "dev:server": "npm run -w server dev",
    "build": "npm run build:shared && npm run build:client && npm run build:server",
    "build:shared": "npm run -w shared build",
    "build:client": "npm run -w client build",
    "build:server": "npm run -w server build"
  }
}
